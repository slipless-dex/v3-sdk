{
  "compilerOptions": {
    "target": "ES2022", "module": "ESNext", "moduleResolution": "Bundler",
    "lib": ["ES2022"], "strict": true, "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true, "esModuleInterop": true, "skipLibCheck": true,
    "isolatedModules": true, "verbatimModuleSyntax": true, "declaration": true,
    "sourceMap": true, "outDir": "dist", "rootDir": "src"
  },
  "include": ["src/**/*"]
}
